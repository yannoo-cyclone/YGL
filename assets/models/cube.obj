# Simple Cube Model
# YGL - Yannoo Graphic Library
# Format: OBJ

# Vertices (8 corners)
v -0.5 0.5 0.5
v 0.5 0.5 0.5
v 0.5 -0.5 0.5
v -0.5 -0.5 0.5
v -0.5 0.5 -0.5
v 0.5 0.5 -0.5
v 0.5 -0.5 -0.5
v -0.5 -0.5 -0.5

# Texture coordinates
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normals
vn 0.0 0.0 1.0   # Front
vn 0.0 0.0 -1.0  # Back
vn 0.0 1.0 0.0   # Top
vn 0.0 -1.0 0.0  # Bottom
vn 1.0 0.0 0.0   # Right
vn -1.0 0.0 0.0  # Left

# Faces
# Front face (z+)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# Back face (z-)
f 8/4/2 7/3/2 6/2/2
f 8/4/2 6/2/2 5/1/2

# Top face (y+)
f 5/1/3 6/2/3 2/2/3
f 5/1/3 2/2/3 1/1/3

# Bottom face (y-)
f 4/4/4 3/3/4 7/3/4
f 4/4/4 7/3/4 8/4/4

# Right face (x+)
f 2/2/5 6/2/5 7/3/5
f 2/2/5 7/3/5 3/3/5

# Left face (x-)
f 1/1/6 5/1/6 8/4/6
f 1/1/6 8/4/6 4/4/6
